# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
plan.out

# CLI configuration files
.terraformrc
terraform.rc

# Lock file (OPTIONAL)
# Usually COMMIT this for consistent provider versions
# .terraform.lock.hcl

# macOS
.DS_Store

# VSCode
.vscode/

# IntelliJ
.idea/

# Logs
*.log